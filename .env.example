NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# Optional: WhatsApp number (with country code, digits only) patients can message from /mi-caso.
# Leave empty to hide the "Continuar por WhatsApp" button.
NEXT_PUBLIC_SUPPORT_WHATSAPP=

# --- Server-only (NOT NEXT_PUBLIC). Used by /api/videoconsulta. Never expose to the browser. ---
# Supabase service-role key (Project Settings → API). Lets the API route write video rooms.
SUPABASE_SERVICE_ROLE_KEY=
# Twilio credentials (console.twilio.com)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# WhatsApp sender, e.g. whatsapp:+14155238886 (Sandbox number for dev)
TWILIO_WHATSAPP_NUMBER=
# SMS sender used as fallback, e.g. +14155238886
TWILIO_SMS_NUMBER=
